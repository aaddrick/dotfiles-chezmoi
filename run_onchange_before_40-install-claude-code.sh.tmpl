#!/usr/bin/env bash
# Installs Claude Code via the official curl installer.
#
# We deliberately use the upstream installer (~/.local/bin/claude) rather
# than the `@anthropic-ai/claude-code` npm package — the installer is the
# preferred distribution channel and pulls down whatever release manifest
# upstream currently points at.
#
# Idempotent: if `claude` is already on PATH (or at the installer's default
# location), we skip. No version pinning — re-runs are triggered by editing
# this script's content (standard run_onchange_ behavior).
#
# Failure policy: matches the other before_ scripts — log and exit 0 so a
# network hiccup doesn't wedge the rest of the apply.
set -uo pipefail

{{ if (or (eq .chezmoi.osRelease.id "nobara") (eq .chezmoi.osRelease.id "fedora")) -}}

log()  { printf '\033[1;34m[claude-code]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[claude-code warn]\033[0m %s\n' "$*" >&2; }

# --- Prerequisite checks ----------------------------------------------------

if ! command -v curl >/dev/null 2>&1; then
  warn "curl not found; skipping claude code install"
  exit 0
fi

# --- Install ----------------------------------------------------------------

CLAUDE_BIN_DEFAULT="$HOME/.local/bin/claude"
if command -v claude >/dev/null 2>&1 || [ -x "$CLAUDE_BIN_DEFAULT" ]; then
  log "claude already installed: $(command -v claude 2>/dev/null || echo "$CLAUDE_BIN_DEFAULT")"
  exit 0
fi

log "Installing Claude Code via official installer"
if curl -fsSL https://claude.ai/install.sh | bash; then
  log "Claude Code installed"
  exit 0
fi

warn "Claude Code installer failed; continuing without it"
exit 0

{{ else -}}
echo "Skipping claude code install: unsupported OS ({{ .chezmoi.osRelease.id }})"
{{ end -}}
