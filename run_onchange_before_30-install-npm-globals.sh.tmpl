#!/usr/bin/env bash
# Installs npm global packages. Runs after 20-install-packages so nodejs is
# already present from the dnf step.
#
# Installs to ~/.npm-global regardless of whether .npmrc has been applied
# yet (we're `before_`, so it may not be). Setting npm_config_prefix via
# env var makes this script self-contained.
#
# Failure policy: matches 20-install-packages — failures logged, exit 0.
set -uo pipefail

{{ if (or (eq .chezmoi.osRelease.id "nobara") (eq .chezmoi.osRelease.id "fedora")) -}}

log()  { printf '\033[1;34m[npm-globals]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[npm-globals warn]\033[0m %s\n' "$*" >&2; }

FAILURES=()
record_failure() { FAILURES+=("$1"); warn "$1"; }

# --- Prerequisite checks ----------------------------------------------------

if ! command -v node >/dev/null 2>&1; then
  warn "node not found — should have been installed by 20-install-packages; skipping"
  exit 0
fi
if ! command -v npm >/dev/null 2>&1; then
  warn "npm not found — should have been installed alongside nodejs; skipping"
  exit 0
fi

# Force the user-level prefix so we never need sudo and never depend on
# .npmrc having been written yet.
export npm_config_prefix="$HOME/.npm-global"
mkdir -p "$npm_config_prefix"
export PATH="$npm_config_prefix/bin:$PATH"

# --- Package list -----------------------------------------------------------
# Common packages install on every machine role; workstation adds language
# servers for the LSP plugins enabled in settings.json.

NPM_PACKAGES=(
  # Gmail MCP server (pouyanafisi/gmail-mcp fork)
  "@pouyanafisi/gmail-mcp"
)

{{ if eq .machineRole "workstation" -}}
NPM_PACKAGES+=(
  # Language servers backing Claude Code LSP plugins:
  #   bash-lsp    -> bash-language-server
  #   php-lsp     -> intelephense (premium license lives at ~/intelephense/)
  #   typescript-lsp -> typescript-language-server + typescript peer
  #   yaml-lsp    -> yaml-language-server
  bash-language-server
  intelephense
  typescript
  typescript-language-server
  yaml-language-server

  # Firebase CLI for web project deploys
  firebase-tools
)
{{ end -}}

# --- Install ----------------------------------------------------------------

installed_version() {
  # Returns the installed version string or empty if the package is missing.
  npm ls -g --depth=0 --parseable=false --json 2>/dev/null \
    | jq -r --arg name "$1" '.dependencies[$name].version // empty' 2>/dev/null
}

for pkg in "${NPM_PACKAGES[@]}"; do
  if [ -n "$(installed_version "$pkg")" ]; then
    log "already installed: $pkg"
    continue
  fi
  log "installing: $pkg"
  if ! npm install -g --silent "$pkg" >/dev/null; then
    record_failure "npm: $pkg"
  fi
done

# --- Summary ----------------------------------------------------------------

if [ "${#FAILURES[@]}" -eq 0 ]; then
  log "All npm globals installed"
  exit 0
fi

warn "Completed with ${#FAILURES[@]} failure(s) — continuing so chezmoi can apply dotfiles:"
for f in "${FAILURES[@]}"; do
  printf '  - %s\n' "$f" >&2
done
exit 0

{{ else -}}
echo "Skipping npm globals: unsupported OS ({{ .chezmoi.osRelease.id }})"
{{ end -}}
