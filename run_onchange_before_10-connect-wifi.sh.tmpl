#!/usr/bin/env bash
# Connects to known wifi networks via NetworkManager, pulling PSKs from
# Bitwarden at runtime. Runs before package install so later steps have net.
#
# Requirements at apply time:
#   - `bw` installed and the vault unlocked (BW_SESSION exported)
#   - `nmcli` available (NetworkManager)
#   - passwordless sudo (set up by bootstrap.sh — /etc/sudoers.d/90-$USER-nopasswd)
#
# Failure policy: each network is attempted independently; failures are
# logged and skipped. Missing prerequisites (bw, nmcli, session, sudoers
# rule) degrade to a warn and skip the whole step rather than aborting
# the apply or — worse — hanging on an interactive password prompt.
set -uo pipefail

{{ if (or (eq .chezmoi.osRelease.id "nobara") (eq .chezmoi.osRelease.id "fedora")) -}}

log()  { printf '\033[1;34m[wifi]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[wifi warn]\033[0m %s\n' "$*" >&2; }

FAILURES=()
record_failure() { FAILURES+=("$1"); warn "$1"; }

# Each entry: "<bitwarden item uuid>|<connection name>"
# - bitwarden item: a LOGIN-type item where `.login.username` is the SSID
#   and `.login.password` is the PSK. Pinned by UUID so (a) duplicates can't
#   silently resolve to the wrong item and (b) the SSID itself is NEVER in
#   the source tree — important now that this repo is public. Get the UUID
#   via: `bw list items --search <query> | jq -r '.[].id'`
# - connection name: local NM profile name; also used as the keyfile basename
#   under /etc/NetworkManager/system-connections/
NETWORKS=(
  "f1905c21-1620-4f56-a17e-b42900a69c81|home-wifi"
)

# --- Prerequisite checks (soft) --------------------------------------------

if ! command -v nmcli >/dev/null 2>&1; then
  warn "nmcli not found; skipping wifi setup"
  exit 0
fi

if ! command -v bw >/dev/null 2>&1; then
  warn "bw not found; skipping wifi setup (run bootstrap.sh to install)"
  exit 0
fi

if [ -z "${BW_SESSION:-}" ]; then
  warn "BW_SESSION not set; skipping wifi setup"
  warn "unlock vault and re-apply:  export BW_SESSION=\$(bw unlock --raw) && chezmoi apply"
  exit 0
fi

# Verify the session actually works before looping.
if ! bw status 2>/dev/null | grep -q '"status":"unlocked"'; then
  warn "Bitwarden vault not unlocked with current BW_SESSION; skipping wifi setup"
  exit 0
fi

# Passwordless sudo must be in place — otherwise sudo calls below would hang
# on a password prompt under a non-interactive `chezmoi apply`.
SUDOERS_FILE="/etc/sudoers.d/90-$(id -un)-nopasswd"
if ! sudo -n test -f "$SUDOERS_FILE" 2>/dev/null; then
  warn "passwordless sudo not configured ($SUDOERS_FILE missing); skipping wifi setup"
  warn "run bootstrap.sh first to set it up"
  exit 0
fi

# --- Per-network loop -------------------------------------------------------
#
# Secret handling: the PSK is NEVER passed via command-line arguments (which
# would be visible to any local process via `ps auxww`). Instead we write a
# complete NM keyfile to a user-owned tempfile using printf (a shell builtin,
# so no argv exposure), then `sudo install` it to /etc/NetworkManager/
# system-connections/ with mode 0600 root:root and tell NM to reload.

NM_SYSTEM_DIR="/etc/NetworkManager/system-connections"

# Read the psk line out of an existing keyfile (if present) so we can detect
# rotation and rewrite only when it actually changed.
existing_keyfile_psk() {
  local path="$1"
  sudo -n test -f "$path" 2>/dev/null || return 1
  sudo -n awk -F= '/^psk=/ {sub(/^psk=/, ""); print; exit}' "$path" 2>/dev/null
}

write_keyfile() {
  local con_name="$1" ssid="$2" psk="$3"
  local target="$NM_SYSTEM_DIR/${con_name}.nmconnection"
  local tmp rc=0
  tmp="$(mktemp)"
  chmod 0600 "$tmp"
  # printf is a bash builtin -> no argv exposure of $psk.
  if ! printf '[connection]\nid=%s\ntype=wifi\n\n[wifi]\nmode=infrastructure\nssid=%s\n\n[wifi-security]\nkey-mgmt=wpa-psk\npsk=%s\n\n[ipv4]\nmethod=auto\n\n[ipv6]\nmethod=auto\n' \
       "$con_name" "$ssid" "$psk" > "$tmp"; then
    rc=1
  elif ! sudo install -o root -g root -m 0600 "$tmp" "$target"; then
    rc=1
  fi
  rm -f "$tmp"
  # Reload is best-effort — if it fails, the keyfile is still on disk and
  # NM will pick it up on next reload/restart. Don't let reload failure
  # mask a successful write.
  [ "$rc" -eq 0 ] && sudo nmcli connection reload >/dev/null 2>&1 || true
  return "$rc"
}

for entry in "${NETWORKS[@]}"; do
  IFS='|' read -r bw_uuid con_name <<<"$entry"
  keyfile="$NM_SYSTEM_DIR/${con_name}.nmconnection"

  log "Fetching SSID + PSK from Bitwarden item $bw_uuid"
  ssid="$(bw get username "$bw_uuid" 2>/dev/null || true)"
  psk="$(bw get password  "$bw_uuid" 2>/dev/null || true)"
  if [ -z "$ssid" ]; then
    record_failure "$con_name: bw item $bw_uuid has no username (SSID)"
    continue
  fi
  if [ -z "$psk" ]; then
    record_failure "$con_name: bw item $bw_uuid has no password (PSK)"
    continue
  fi

  # Detect rotation: compare the bw psk against what's already on disk.
  existing_psk="$(existing_keyfile_psk "$keyfile" || true)"
  if [ -n "$existing_psk" ] && [ "$existing_psk" = "$psk" ]; then
    log "Keyfile already current: $con_name"
    unset psk existing_psk
    continue
  fi

  if [ -n "$existing_psk" ]; then
    log "PSK rotated for $con_name; rewriting keyfile"
  else
    log "Creating keyfile for $con_name"
  fi

  if ! write_keyfile "$con_name" "$ssid" "$psk"; then
    record_failure "$con_name: failed to write keyfile"
    unset psk ssid existing_psk
    continue
  fi

  # Best-effort bring-up; safe to fail (radio may be off, profile will
  # auto-activate later when NM sees the SSID).
  sudo nmcli connection up "$con_name" >/dev/null 2>&1 \
    && log "Connected: $con_name" \
    || log "Profile written but not active yet: $con_name (NM will auto-connect when SSID is in range)"

  unset psk ssid existing_psk
done

# --- Summary ----------------------------------------------------------------

if [ "${#FAILURES[@]}" -eq 0 ]; then
  log "Wifi setup complete"
  exit 0
fi

warn "Completed with ${#FAILURES[@]} failure(s):"
for f in "${FAILURES[@]}"; do
  printf '  - %s\n' "$f" >&2
done
# Exit 0: wifi failures are non-fatal for the apply as a whole.
exit 0

{{ else -}}
echo "Skipping wifi setup: unsupported OS ({{ .chezmoi.osRelease.id }})"
{{ end -}}
